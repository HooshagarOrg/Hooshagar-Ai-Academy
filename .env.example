# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── App Config ───────────────────────────────────────────────────
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=change-me-to-random-32-chars-minimum

# ── Google Gemini ────────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSy...

# ── Rate Limiting (Vercel KV / Upstash) ──────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── OpenRouter — 3 کلید (Tier 2-3-4) ────────────────────────────
# Key A → Tier 2: مدل‌های 200B+ (deepseek-r1, nemotron-ultra, ...)
OPENROUTER_API_KEY=sk-or-v1-...
# Key B → Tier 3: مدل‌های 32-70B (qwen3-32b, llama-3.3-70b, ...)
OPENROUTER_API_KEY_B=sk-or-v1-...
# Key C → Tier 5: مدل‌های سریع 7-24B (mistral-small, gemma-3-12b, ...)
OPENROUTER_API_KEY_C=sk-or-v1-...

# ── Z.ai (Tier 2 — GLM-4.7-Flash رایگان) ───────────────────────
# https://docs.z.ai/api-reference/introduction
ZAI_API_KEY=
# ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_MODEL=glm-4.7-flash

# ── SMS (Kavenegar) ──────────────────────────────────────────────
KAVENEGAR_API_KEY=...
KAVENEGAR_SENDER=...

# ── Zarinpal (پرداخت) ────────────────────────────────────────────
ZARINPAL_MERCHANT_ID=...

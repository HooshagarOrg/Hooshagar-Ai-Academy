# ========================================
# Environment Variables - هوشاگر
# ========================================
# این فایل را کپی کرده و به نام .env.local ذخیره کنید
# تمام مقادیر YOUR_* را با مقادیر واقعی جایگزین کنید

# ========================================
# Supabase Configuration (اجباری)
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase Service Role (فقط در سرور استفاده می‌شود)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ========================================
# Cloudflare Workers Proxy (برای دور زدن فیلترینگ ایران)
# ========================================
NEXT_PUBLIC_SUPABASE_PROXY=https://YOUR_SUPABASE_PROXY.workers.dev
# اتصال مستقیم Node در dev (با VPN) — در production همان پراکسی
SUPABASE_SERVER_URL=https://YOUR_PROJECT.supabase.co
# USE_SUPABASE_PROXY_IN_DEV=true
NEXT_PUBLIC_GEMINI_PROXY=https://YOUR_GEMINI_PROXY.workers.dev
NEXT_PUBLIC_GROQ_PROXY=https://YOUR_GROQ_PROXY.workers.dev

# ========================================
# AI Configuration
# ========================================
# Google Gemini API (اصلی - رایگان)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_API_KEY_2=YOUR_BACKUP_GOOGLE_API_KEY

# OpenRouter API (fallback - Tier 3-5)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_API_KEY_B=YOUR_OPENROUTER_API_KEY_B
OPENROUTER_API_KEY_C=YOUR_OPENROUTER_API_KEY_C

# Z.ai API (Tier 2 — GLM رایگان)
# https://docs.z.ai/api-reference/introduction
ZAI_API_KEY=YOUR_ZAI_API_KEY
# ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_MODEL=glm-4.7-flash

# Groq Cloud (Tier 3 — بعد از Z.ai، قبل از OpenRouter)
# https://console.groq.com/keys
# کلید استخر اصلی — ایمیل ۱ (جدا از آواتار)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_BASE_URL=https://api.groq.com/openai/v1
# NEXT_PUBLIC_GROQ_PROXY تنظیم می‌شود (بخش «Cloudflare Workers Proxy» بالا)

# ========================================
# Avatar «هوشیار» — استخر API جدا
# ========================================
AVATAR_GOOGLE_API_KEY_1=YOUR_AVATAR_GOOGLE_KEY_1
AVATAR_GOOGLE_API_KEY_2=YOUR_AVATAR_GOOGLE_KEY_2
AVATAR_GOOGLE_API_KEY_3=YOUR_AVATAR_GOOGLE_KEY_3
AVATAR_GOOGLE_API_KEY_4=YOUR_AVATAR_GOOGLE_KEY_4
AVATAR_GOOGLE_API_KEY_5=YOUR_AVATAR_GOOGLE_KEY_5
AVATAR_GOOGLE_API_KEY_6=YOUR_AVATAR_GOOGLE_KEY_6
AVATAR_GOOGLE_API_KEY_7=YOUR_AVATAR_GOOGLE_KEY_7
AVATAR_GOOGLE_API_KEY_8=YOUR_AVATAR_GOOGLE_KEY_8
AVATAR_GOOGLE_API_KEY_9=YOUR_AVATAR_GOOGLE_KEY_9
AVATAR_GOOGLE_API_KEY_10=YOUR_AVATAR_GOOGLE_KEY_10
AVATAR_GOOGLE_API_KEY_11=YOUR_AVATAR_GOOGLE_KEY_11
AVATAR_GOOGLE_API_KEY_12=YOUR_AVATAR_GOOGLE_KEY_12
AVATAR_GOOGLE_API_KEY_13=YOUR_AVATAR_GOOGLE_KEY_13
AVATAR_GOOGLE_API_KEY_14=YOUR_AVATAR_GOOGLE_KEY_14
AVATAR_GOOGLE_API_KEY_15=YOUR_AVATAR_GOOGLE_KEY_15
AVATAR_GOOGLE_API_KEY_16=YOUR_AVATAR_GOOGLE_KEY_16
AVATAR_GOOGLE_API_KEY_17=YOUR_AVATAR_GOOGLE_KEY_17
AVATAR_GOOGLE_API_KEY_18=YOUR_AVATAR_GOOGLE_KEY_18
AVATAR_GOOGLE_API_KEY_19=YOUR_AVATAR_GOOGLE_KEY_19
AVATAR_GOOGLE_API_KEY_20=YOUR_AVATAR_GOOGLE_KEY_20
AVATAR_OPENROUTER_API_KEY=YOUR_AVATAR_OPENROUTER_KEY
# Groq آواتار — ایمیل ۲ (جدا از GROQ_API_KEY اصلی)
AVATAR_GROQ_API_KEY=YOUR_AVATAR_GROQ_API_KEY
AVATAR_GROQ_MODEL=llama-3.1-8b-instant
AVATAR_GEMINI_MODEL=gemini-1.5-flash
AVATAR_OR_MODEL_1=google/gemini-2.5-flash-lite:free
AVATAR_OR_MODEL_2=deepseek/deepseek-chat-v3.1:free
AVATAR_OR_MODEL_3=meta-llama/llama-3.3-70b-instruct:free
AVATAR_OR_FALLBACK=openrouter/free
AVATAR_DAILY_MESSAGE_LIMIT=15

# AI Model Configuration
AI_MODEL_DEFAULT=gemini-1.5-pro
AI_MODEL_FAST=gemini-1.5-flash
AI_MODEL_VISION=gemini-1.5-pro-vision
AI_MODEL_FALLBACK=moonshotai/kimi-k2-thinking

# ========================================
# Storage Configuration (اختیاری)
# ========================================
# Arvan Cloud Storage (برای فایل‌ها)
ARVAN_ACCESS_KEY=YOUR_ARVAN_ACCESS_KEY
ARVAN_SECRET_KEY=YOUR_ARVAN_SECRET_KEY
ARVAN_ENDPOINT=s3.ir-thr-at1.arvanstorage.ir
ARVAN_BUCKET=hooshagar

# ========================================
# Authentication & Security
# ========================================
# NextAuth Secret (برای JWT)
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_MINIMUM_32_CHARACTERS
NEXTAUTH_URL=http://localhost:3000

# JWT Secret (برای token signing)
JWT_SECRET=YOUR_JWT_SECRET_MINIMUM_32_CHARACTERS

# ========================================
# Application Configuration
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=هوشاگر
NODE_ENV=development

# ========================================
# Rate Limiting (اختیاری)
# ========================================
# Upstash Redis (برای rate limiting)
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# یا استفاده از Vercel KV
KV_REST_API_URL=YOUR_VERCEL_KV_URL
KV_REST_API_TOKEN=YOUR_VERCEL_KV_TOKEN

# ========================================
# Skyroom — کلاس مجازی (سرور فقط)
# ========================================
SKYROOM_API_KEY=YOUR_SKYROOM_API_KEY
SKYROOM_API_BASE_URL=https://www.skyroom.online/skyroom/api

# ========================================
# Monitoring & Analytics (اختیاری)
# ========================================
# Sentry (Error tracking)
SENTRY_DSN=YOUR_SENTRY_DSN
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=YOUR_ANALYTICS_ID

# ========================================
# Email Service (اختیاری)
# ========================================
# برای ارسال ایمیل (مثلاً گزارش‌ها)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD

# ========================================
# Feature Flags (اختیاری)
# ========================================
ENABLE_AI_FEATURES=true
ENABLE_GAMIFICATION=true
ENABLE_PARENT_REPORTS=true
ENABLE_NOTIFICATIONS=true

# ========================================
# Development Only
# ========================================
# در production این‌ها را حذف کنید
SKIP_ENV_VALIDATION=false
NEXT_TELEMETRY_DISABLED=1

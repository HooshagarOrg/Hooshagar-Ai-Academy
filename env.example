# ========================================
# Environment Variables - هوشاگر
# ========================================
# این فایل را کپی کرده و به نام .env.local ذخیره کنید
# تمام مقادیر YOUR_* را با مقادیر واقعی جایگزین کنید

# ========================================
# Supabase Configuration (اجباری)
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase Service Role (فقط در سرور استفاده می‌شود)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ========================================
# Cloudflare Workers Proxy (برای دور زدن فیلترینگ ایران)
# ========================================
NEXT_PUBLIC_SUPABASE_PROXY=https://YOUR_SUPABASE_PROXY.workers.dev
NEXT_PUBLIC_GEMINI_PROXY=https://YOUR_GEMINI_PROXY.workers.dev

# ========================================
# AI Configuration
# ========================================
# Google Gemini API (اصلی - رایگان)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_API_KEY_2=YOUR_BACKUP_GOOGLE_API_KEY

# OpenRouter API (fallback - پولی)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# AI Model Configuration
AI_MODEL_DEFAULT=gemini-1.5-pro
AI_MODEL_FAST=gemini-1.5-flash
AI_MODEL_VISION=gemini-1.5-pro-vision
AI_MODEL_FALLBACK=moonshotai/kimi-k2-thinking

# ========================================
# Storage Configuration (اختیاری)
# ========================================
# Arvan Cloud Storage (برای فایل‌ها)
ARVAN_ACCESS_KEY=YOUR_ARVAN_ACCESS_KEY
ARVAN_SECRET_KEY=YOUR_ARVAN_SECRET_KEY
ARVAN_ENDPOINT=s3.ir-thr-at1.arvanstorage.ir
ARVAN_BUCKET=hooshagar

# ========================================
# Authentication & Security
# ========================================
# NextAuth Secret (برای JWT)
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_MINIMUM_32_CHARACTERS
NEXTAUTH_URL=http://localhost:3000

# JWT Secret (برای token signing)
JWT_SECRET=YOUR_JWT_SECRET_MINIMUM_32_CHARACTERS

# ========================================
# Application Configuration
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=هوشاگر
NODE_ENV=development

# ========================================
# Rate Limiting (اختیاری)
# ========================================
# Upstash Redis (برای rate limiting)
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# یا استفاده از Vercel KV
KV_REST_API_URL=YOUR_VERCEL_KV_URL
KV_REST_API_TOKEN=YOUR_VERCEL_KV_TOKEN

# ========================================
# Monitoring & Analytics (اختیاری)
# ========================================
# Sentry (Error tracking)
SENTRY_DSN=YOUR_SENTRY_DSN
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=YOUR_ANALYTICS_ID

# ========================================
# Email Service (اختیاری)
# ========================================
# برای ارسال ایمیل (مثلاً گزارش‌ها)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD

# ========================================
# Feature Flags (اختیاری)
# ========================================
ENABLE_AI_FEATURES=true
ENABLE_GAMIFICATION=true
ENABLE_PARENT_REPORTS=true
ENABLE_NOTIFICATIONS=true

# ========================================
# Development Only
# ========================================
# در production این‌ها را حذف کنید
SKIP_ENV_VALIDATION=false
NEXT_TELEMETRY_DISABLED=1

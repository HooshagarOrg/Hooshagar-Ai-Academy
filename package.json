{
  "name": "hooshagar",
  "version": "1.0.0",
  "description": "سیستم عامل هوشمند مدیریت مدارس - AI-Native School Management System",
  "private": true,
  "license": "UNLICENSED",
  "author": "Hooshagar",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "node --dns-result-order=ipv4first ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "generate-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > types/database.types.ts",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset",
    "db:dump": "supabase db dump -f backup.sql",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom='**/*.{ts,tsx}' --collectCoverageFrom='!**/*.d.ts' --collectCoverageFrom='!**/node_modules/**'",
    "test:e2e": "playwright test",
    "test-google": "node scripts/test-google.js",
    "test-openrouter": "node scripts/test-openrouter.js",
    "verify-env": "node scripts/verify-env.js",
    "smoke:prod": "node scripts/phase-c-smoke.mjs",
    "prepare-logo": "node scripts/prepare-logo.js",
    "generate-icons": "node scripts/generate-pwa-icons.js",
    "logo:all": "node scripts/prepare-logo.js && node scripts/generate-pwa-icons.js",
    "test:recaptcha": "node scripts/test-recaptcha.js"
  },

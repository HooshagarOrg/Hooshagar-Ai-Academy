# ════════════════════════════════════════════
# 🔐 Environment Variables Template
# ════════════════════════════════════════════
# کپی کنید به .env.local و مقادیر واقعی را جایگزین کنید

# ════════════════════════════════════════════
# 📡 Supabase (Database + Auth)
# ════════════════════════════════════════════
# دریافت از: https://supabase.com > Your Project > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ════════════════════════════════════════════
# 🤖 AI Providers
# ════════════════════════════════════════════

# OpenRouter (Primary - Tier A, C, D, E, F)
# دریافت از: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Google Gemini (Tier B - رایگان!)
# دریافت از: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy-your-key-here

# Gemini Proxy (اختیاری - برای Load Balancing)
GEMINI_PROXY_URL=https://gemini-proxy.your-worker.workers.dev

# ════════════════════════════════════════════
# 📱 Kavenegar (SMS)
# ════════════════════════════════════════════
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_SENDER=10008663
KAVENEGAR_TEMPLATE_NAME=hooshagar-verify

# ════════════════════════════════════════════
# 🗄️ Arvan Cloud Storage
# ════════════════════════════════════════════
ARVAN_ACCESS_KEY=your-access-key
ARVAN_SECRET_KEY=your-secret-key
ARVAN_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_BUCKET_NAME=hooshagar-prod
ARVAN_REGION=ir-thr-at1
ARVAN_CDN=https://your-bucket.cdn.arvanstorage.ir

# ════════════════════════════════════════════
# 🔐 reCAPTCHA v3
# ════════════════════════════════════════════
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Ldf-your-site-key
RECAPTCHA_SECRET_KEY=6Ldf-your-secret-key

# ════════════════════════════════════════════
# 🐛 Sentry (Error Tracking)
# ════════════════════════════════════════════
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ════════════════════════════════════════════
# ⚙️ OTP & App Settings
# ════════════════════════════════════════════
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=10
OTP_BLOCK_DURATION=10

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ════════════════════════════════════════════
# 🔑 NextAuth
# ════════════════════════════════════════════
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32









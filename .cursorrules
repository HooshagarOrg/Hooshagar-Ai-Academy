# اشتباهات رایج - هرگز تکرار نشود
# ========================================

❌ DON'T: ارسال کل codebase به AI
✅ DO: فقط فایل‌های مرتبط را انتخاب کن

❌ DON'T: استفاده از any در TypeScript
✅ DO: از interface/type معتبر استفاده کن

❌ DON'T: Hardcode API keys
✅ DO: از environment variables استفاده کن

❌ DON'T: فراموش کردن error handling
✅ DO: همیشه try/catch + toast error

❌ DON'T: بدون loading state
✅ DO: همیشه Skeleton/Spinner نمایش بده

❌ DON'T: کامیت بدون تست
✅ DO: npm run type-check قبل از هر commit

❌ DON'T: انتخاب select * از database
✅ DO: فقط ستون‌های مورد نیاز را select کن

❌ DON'T: text-justify برای فارسی
✅ DO: text-right با line-height: 1.8

# ========================================
# AI Integration Patterns
# ========================================

## Student Analyzer AI (اولویت 1)
1. API Route: POST /api/analyze
2. ابتدا Gemini-1.5-pro امتحان کن
3. اگر fail → fallback به kimi-k2
4. Prompt must include: studentData, analysisType, dateRange
5. Response: {analysis, recommendations, strengths, weaknesses, risk_level}
6. همیشه در ai_analyses table ذخیره کن
7. از Redis cache 24 ساعته استفاده کن

## Problem Solver OCR (اولویت 2)
1. API Route: POST /api/ocr
2. ابتدا Gemini Vision امتحان کن
3. اگر fail → fallback به Claude Sonnet
4. محدودیت حجم: max 5MB
5. Response: {solution, explanation, confidence}

## Study Buddy RAG (اولویت 3)
1. API Route: POST /api/rag/query
2. فقط از Gemini استفاده کن (ارزان‌تر)
3. ابتدا embedding بگیر سپس similarity search
4. threshold: 0.78
5. Response: {answer, sources}

# ========================================
# Database Query Patterns
# ========================================

## ✅ GOOD:
const { data, error } = await supabase
  .from('students')
  .select('id, full_name, grade')
  .eq('class_id', teacherClassId)
  .limit(20);

if (error) {
  console.error('خطای دریافت دانش‌آموزان:', error);
  throw new Error('دریافت اطلاعات ناموفق');
}

## ❌ BAD:
const { data } = await supabase.from('students').select('*');

# ========================================
# Row Level Security (RLS) Patterns
# ========================================

-- هر table باید RLS داشته باشد
ALTER TABLE students ENABLE ROW LEVEL SECURITY;

-- معلم فقط دانش‌آموزان کلاس خودش را ببیند
CREATE POLICY "teachers_see_own_students"
ON students FOR SELECT
USING (
  class_id IN (
    SELECT id FROM classes WHERE teacher_id = auth.uid()
  )
);

-- والدین فقط فرزند خودشان
CREATE POLICY "parents_see_own_children"
ON students FOR SELECT
USING (parent_id = auth.uid());

-- دانش‌آموز فقط خودش
CREATE POLICY "students_see_self"
ON students FOR SELECT
USING (user_id = auth.uid());

# ========================================
# Zod Validation Patterns
# ========================================

import { z } from 'zod';

const studentSchema = z.object({
  full_name: z.string().min(2, 'نام باید حداقل 2 کاراکتر باشد').max(100),
  grade: z.number().int().min(1).max(12),
  email: z.string().email('ایمیل نامعتبر است').optional(),
});

// در API route
const body = await req.json();
const result = studentSchema.safeParse(body);

if (!result.success) {
  return Response.json({
    error: 'داده‌های نامعتبر',
    details: result.error.issues
  }, { status: 400 });
}

# ========================================
# Rate Limiting Pattern
# ========================================

import { Ratelimit } from '@upstash/ratelimit';
import { kv } from '@vercel/kv';

const limiter = new Ratelimit({
  redis: kv,
  limiter: Ratelimit.slidingWindow(5, '1 m'), // 5 req/min
});

export async function POST(req: Request) {
  const { success } = await limiter.limit(req.ip || 'anonymous');
  
  if (!success) {
    return Response.json({ 
      error: 'درخواست‌های زیاد. لطفاً صبر کنید.' 
    }, { status: 429 });
  }
}

# ========================================
# AI Error Recovery Pattern
# ========================================

async function callAIWithFallback(prompt: string) {
  try {
    // Try Gemini first (رایگان)
    const response = await callGemini(prompt);
    return { ...response, provider: 'google', cost: 0 };
  } catch (error) {
    console.warn('Gemini failed, trying OpenRouter...');
    
    try {
      // Fallback to OpenRouter
      const response = await callOpenRouter(prompt, 'kimi-k2');
      return { ...response, provider: 'openrouter', cost: 0.02 };
    } catch (fallbackError) {
      // Ultimate fallback: cached response
      const cached = await getCachedResponse(prompt);
      if (cached) return { ...cached, from_cache: true };
      
      throw new Error('تمام سرویس‌های AI در دسترس نیستند');
    }
  }
}

# ========================================
# Performance Targets
# ========================================

- API Response (بدون AI): < 500ms
- AI Response: < 15s (با loading indicator)
- Dashboard Load: < 1s
- اولین بارگذاری صفحه: < 3s
- Cache Hit Rate: > 50%
- TypeScript Compile: < 5s

## Caching Strategy:
- Student list: 5 min (Redis)
- AI responses: 24 hours (PostgreSQL)
- Static assets: 1 year (CDN)


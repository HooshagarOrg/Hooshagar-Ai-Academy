# 🌍 هوشاگر - Environment Variables
# کپی کنید به .env.local و مقادیر واقعی را وارد کنید

# =====================================
# 🔐 Supabase Configuration
# =====================================
# گرفتن از: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ DANGER: این کلید را هرگز در client expose نکنید
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================
# 🤖 OpenRouter (AI Models)
# =====================================
# گرفتن از: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: برای tracking استفاده
OPENROUTER_APP_NAME=hooshagar
OPENROUTER_SITE_URL=https://hooshagar.ir

# =====================================
# ☁️ Arvan Cloud S3 Storage
# =====================================
# گرفتن از: https://panel.arvancloud.ir/dashboard/s3
ARVAN_ACCESS_KEY=your-access-key
ARVAN_SECRET_KEY=your-secret-key
ARVAN_BUCKET_NAME=hooshagar-storage
ARVAN_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_REGION=ir-thr-at1

# =====================================
# 🚀 Vercel KV (Redis Cache)
# =====================================
# این متغیرها در Vercel خودکار set می‌شوند
# برای development local، از Upstash استفاده کنید
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# =====================================
# 🔑 Application Secrets
# =====================================
# برای JWT signing - از یک رشته تصادفی قوی استفاده کنید
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# برای encryption داده‌های حساس
ENCRYPTION_KEY=your-encryption-key-32-chars

# =====================================
# 🌐 Application URLs
# =====================================
# Development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production (بعد از deploy)
# NEXT_PUBLIC_APP_URL=https://hooshagar.vercel.app

# =====================================
# 📧 Email Service (Optional)
# =====================================
# برای ارسال گزارش به والدین
# می‌توانید از Resend یا Mailgun استفاده کنید
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@hooshagar.ir

# =====================================
# 💳 Payment Gateway (زرین‌پال)
# =====================================
# گرفتن از: https://www.zarinpal.com/panel
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=true  # در production false کنید

# =====================================
# 📊 Analytics & Monitoring (Optional)
# =====================================
# Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# =====================================
# 🧪 Development & Testing
# =====================================
# Environment mode
NODE_ENV=development  # production در سرور

# Debug mode
DEBUG=false

# Skip AI calls in development (use mock data)
USE_MOCK_AI=false

# =====================================
# 🎯 Feature Flags
# =====================================
# فعال/غیرفعال کردن features بدون deploy
FEATURE_TALENT_GARDEN=true
FEATURE_OCR=true
FEATURE_RAG=true
FEATURE_STORY_WIZARD=true
FEATURE_PARENT_REPORTS=true

# =====================================
# 🔧 Advanced Settings
# =====================================
# Rate limiting (requests per minute)
RATE_LIMIT_AI=5
RATE_LIMIT_API=60

# AI Model selection (برای fallback)
DEFAULT_AI_MODEL=moonshot/kimi-k2-thinking
FALLBACK_AI_MODEL=google/gemini-flash-1.5

# Maximum file upload size (MB)
MAX_UPLOAD_SIZE=5

# Session timeout (hours)
SESSION_TIMEOUT=24

# =====================================
# 📝 Notes
# =====================================
# - همه متغیرهای NEXT_PUBLIC_* در client قابل دسترسی هستند
# - متغیرهای بدون NEXT_PUBLIC_ فقط در server هستند
# - هرگز secrets را commit نکنید
# - در production، از secret management استفاده کنید
# نمونه .env برای Docker روی VPS
# کپی: cp .env.docker.example .env  (یا از env.example)
# سپس مقادیر واقعی را جایگزین کنید.

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# --- اجباری ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# --- URL اپ (IP یا دامنه) ---
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP:3000
NEXTAUTH_URL=http://YOUR_SERVER_IP:3000
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_MINIMUM_32_CHARACTERS
JWT_SECRET=YOUR_JWT_SECRET_MINIMUM_32_CHARACTERS

# --- اختیاری: proxy ایران ---
# NEXT_PUBLIC_SUPABASE_PROXY=https://YOUR_SUPABASE_PROXY.workers.dev
# NEXT_PUBLIC_GEMINI_PROXY=https://YOUR_GEMINI_PROXY.workers.dev

# --- اختیاری: SMS، پرداخت، storage ---
# KAVENEGAR_API_KEY=
# ARVAN_ACCESS_KEY=
# ARVAN_SECRET_KEY=
# SKYROOM_API_KEY=

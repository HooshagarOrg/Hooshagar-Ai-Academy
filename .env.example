# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── App Config ───────────────────────────────────────────────────
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Gemini — 10 کلید (Round-Robin) ────────────────────────
# هر قابلیت از مدل جداگانه‌ای استفاده می‌کند تا سقف رایگان تقسیم شود
GOOGLE_API_KEY_1=AIzaSy...
GOOGLE_API_KEY_2=AIzaSy...
GOOGLE_API_KEY_3=AIzaSy...
GOOGLE_API_KEY_4=AIzaSy...
GOOGLE_API_KEY_5=AIzaSy...
GOOGLE_API_KEY_6=AIzaSy...
GOOGLE_API_KEY_7=AIzaSy...
GOOGLE_API_KEY_8=AIzaSy...
GOOGLE_API_KEY_9=AIzaSy...
GOOGLE_API_KEY_10=AIzaSy...

# ── OpenRouter — 3 کلید (Tier 2-3-4) ────────────────────────────
# Key A → Tier 2: مدل‌های 200B+ (deepseek-r1, nemotron-ultra, ...)
OPENROUTER_API_KEY=sk-or-v1-...
# Key B → Tier 3: مدل‌های 32-70B (qwen3-32b, llama-3.3-70b, ...)
OPENROUTER_API_KEY_B=sk-or-v1-...
# Key C → Tier 4: مدل‌های سریع 7-24B (mistral-small, gemma-3-12b, ...)
OPENROUTER_API_KEY_C=sk-or-v1-...

# ── SMS (Kavenegar) ──────────────────────────────────────────────
KAVENEGAR_API_KEY=...
KAVENEGAR_SENDER=...

# ── Zarinpal (پرداخت) ────────────────────────────────────────────
ZARINPAL_MERCHANT_ID=...
